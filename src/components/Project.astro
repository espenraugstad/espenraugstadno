---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
---

<article class="border-t border-gray-200 py-4 w-full bg-slate-200 p-4 rounded-xl">
  <a href={`/projects/${project.id}`}>
    <h3 class="text-xl font-bold mb-2">{project.data.title}</h3>
  </a>
  {
    project.data.featuredImage && (
      <Image
        src={project.data.featuredImage}
        alt={project.data.title}
        width={600}
        class="my-4 shadow-md rounded-lg object-cover"
      />
    )
  }
  <p>{project.data.description}</p>
  <ul class="flex flex-wrap gap-2 mt-2">
    {
      project.data.technologies.map((tech) => (
        <li class="bg-blue-400 px-2 py-1 rounded-md text-black text-sm">{tech}</li>
      ))
    }
  </ul>
</article>
