---
interface Props {
  startDate: string;
  endDate: string;
  study: string;
  institution: string;
  description: string;
}

const { startDate, endDate, study, institution, description } = Astro.props;
---
<div class="mb-6">
  <h3 class="text-xl font-bold">{study}</h3>
  <p class="font-semibold text-gray-900">{institution}</p>
  <p class="text-sm text-gray-900 mb-2"><span>{startDate} - {endDate}</span></p>
  <p>{description}</p>
</div>
